{
  "name": "smart-ime",
  "version": "0.1.0",
  "description": "桌面端智能输入法 - Electron + React + TypeScript",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "bash -c 'unset ELECTRON_RUN_AS_NODE && vite'",
    "build": "tsc && vite build && node scripts/copy-entry.cjs",
    "preview": "vite preview",
    "electron:build": "tsc && vite build && node scripts/copy-entry.cjs && electron-builder",
    "electron:build:win": "tsc && vite build && node scripts/copy-entry.cjs && electron-builder --win",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "koffi": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
