    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "koffi": "^3.0.1",
    "pinyin-match": "^1.2.10",
    "pinyin-pro": "^3.19.6",
