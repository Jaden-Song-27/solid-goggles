{
  "name": "smart-ime",
  "version": "0.1.0",
  "description": "桌面端智能输入法 - Electron + React + TypeScript",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
